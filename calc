<!DOCTYPE html>
<html>
<head>
<title>Health Behavior Prediction</title>

<style>
body{
font-family: Arial;
background:#f2f5f7;
padding:40px;
}

.container{
background:white;
padding:30px;
max-width:650px;
margin:auto;
border-radius:8px;
box-shadow:0 4px 10px rgba(0,0,0,0.1);
}

h2{
text-align:center;
}

input{
width:100%;
padding:8px;
margin-bottom:15px;
}

button{
background:#0077cc;
color:white;
padding:12px;
border:none;
width:100%;
font-size:16px;
border-radius:5px;
cursor:pointer;
}

.results{
margin-top:20px;
font-size:18px;
}
</style>

</head>

<body>

<div class="container">

<h2>Predicted Health Behaviors</h2>

<h3>Preexisting Health Inputs</h3>

Height (m)
<input id="height" type="number" step="0.01">

Weight (kg)
<input id="weight" type="number">

Blood Pressure
<input id="bp" type="number">

Heart Rate
<input id="hr" type="number">

Cholesterol
<input id="cholesterol" type="number">

Glucose
<input id="glucose" type="number">

Insulin
<input id="insulin" type="number">

<button onclick="predict()">Predict Health Behaviors</button>

<div class="results" id="output"></div>

</div>

<script>

function predict(){

// Dataset means from descriptive table
let sleep_hours = 7.002
let sleep_quality = 2.51
let work_hours = 8.001
let physical_activity = 3.038
let calorie_intake = 2201.43
let sugar_intake = 60.05
let alcohol = 2.00
let smoking = 2.00
let water = 2.006

document.getElementById("output").innerHTML =

"<b>Predicted Mean Health Behaviors (Dataset Average)</b><br><br>" +

"Sleep Hours: " + sleep_hours.toFixed(2) + "<br>" +
"Sleep Quality: " + sleep_quality.toFixed(2) + "<br>" +
"Work Hours: " + work_hours.toFixed(2) + "<br>" +
"Physical Activity Level: " + physical_activity.toFixed(2) + "<br>" +
"Calorie Intake: " + calorie_intake.toFixed(0) + " kcal<br>" +
"Sugar Intake: " + sugar_intake.toFixed(2) + " g<br>" +
"Alcohol Consumption Level: " + alcohol.toFixed(2) + "<br>" +
"Smoking Level: " + smoking.toFixed(2) + "<br>" +
"Water Intake: " + water.toFixed(2) + " L"

}

</script>

</body>
</html>
